SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/audiomind
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change_me
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=3
JWT_SECRET=replace-with-long-random-secret
JWT_ACCESS_EXPIRATION_SECONDS=86400
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
STT_PROVIDER=deepgram
ANALYSIS_PROVIDER=gemini
DEEPGRAM_API_KEY=your_deepgram_key_here
DEEPGRAM_REALTIME_MODEL=nova-2
DEEPGRAM_BATCH_MODEL=nova-2
DEEPGRAM_LANGUAGE=vi
OPENAI_API_KEY=your_openai_key_here
OPENAI_ANALYSIS_MODEL=
OPENAI_SUMMARY_MODEL=
GEMINI_API_KEY=your-gemini-api-key
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash
GEMINI_SUMMARY_MODEL=gemini-2.5-flash
LOCAL_WHISPER_ENABLED=false
OLLAMA_ENABLED=false
