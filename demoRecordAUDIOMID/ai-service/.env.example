# Database
POSTGRES_USER=audiomind
POSTGRES_PASSWORD=change-me
POSTGRES_DB=audiomind
DATABASE_URL=postgresql://audiomind:change-me@db:5432/audiomind

# Security
JWT_SECRET=replace-with-long-random-secret
JWT_ACCESS_EXPIRATION_SECONDS=86400

# STT Provider Selection (batch & realtime)
# Options: deepgram, local_whisper
# - deepgram: Uses Deepgram API for both realtime (WebSocket) and batch (prerecorded) transcription
# - local_whisper: Uses local Whisper model (CPU/CUDA)
STT_PROVIDER=deepgram

# Deepgram Configuration (for batch & realtime)
DEEPGRAM_API_KEY=your_deepgram_key_here
DEEPGRAM_REALTIME_MODEL=nova-2
DEEPGRAM_BATCH_MODEL=nova-2
DEEPGRAM_LANGUAGE=vi

# Fallback to Local Whisper
# - When true: batch STT falls back to Whisper if Deepgram fails
# - When false: batch STT raises error if Deepgram unavailable
LOCAL_WHISPER_ENABLED=true

# API Keys
OPENAI_API_KEY=your_openai_key_here
ANALYSIS_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash
GEMINI_SUMMARY_MODEL=gemini-2.5-flash
GEMINI_MAX_SINGLE_REQUEST_CHARS=50000
GEMINI_REQUEST_DELAY_SECONDS=15
OPENAI_ANALYSIS_MODEL=
OPENAI_SUMMARY_MODEL=
OLLAMA_ENABLED=false

# Deepgram Diagnostic (keep false for normal dev/prod)
# - DEEPGRAM_SIMPLIFY_STREAMING_URL: Diagnostic only. Keep false unless isolating Deepgram URL behavior.
# - DEEPGRAM_DEBUG_RAW_MESSAGES: Diagnostic only. Logs capped raw Deepgram text frames; keep false normally.
DEEPGRAM_SIMPLIFY_STREAMING_URL=false
DEEPGRAM_DEBUG_RAW_MESSAGES=false

# STT Scale-out Ownership (multi-replica ai-service deployments)
# - STT_ENABLE_DISTRIBUTED_OWNERSHIP: Keep enabled for scale-out
# - STT_OWNERSHIP_ENABLED: Keep enabled for scale-out
# - STT_REPLICA_ID: Optional stable replica identity. Leave blank for process-local UUID.
STT_ENABLE_DISTRIBUTED_OWNERSHIP=true
STT_OWNERSHIP_ENABLED=true
STT_OWNERSHIP_REDIS_URL=redis://redis:6379/2
STT_REPLICA_ID=
STT_OWNERSHIP_LEASE_TTL_SECONDS=30
STT_OWNERSHIP_COOLDOWN_TTL_SECONDS=300

HUGGINGFACE_TOKEN=your_token_here

# Server
HOST=0.0.0.0
PORT=8000

# Storage
AUDIO_STORAGE_PATH=./storage/audio
TEMP_STORAGE_PATH=./storage/temp

# Model Settings
WHISPER_MODEL=base
DEVICE=auto  # auto prefers cuda when available, otherwise cpu
ENABLE_SPEAKER_DIARIZATION=true
DEEPGRAM_DIARIZE=true
LAZY_LOAD_MODELS=true

# Processing
MAX_CHUNK_DURATION=30
VAD_THRESHOLD=0.5

AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama-service:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_TIMEOUT_SECONDS=300
