# Database
POSTGRES_USER=audiomind
POSTGRES_PASSWORD=change-me
POSTGRES_DB=audiomind
DATABASE_URL=postgresql://audiomind:change-me@db:5432/audiomind
OPENAI_API_KEY=your_api_key_here
DEEPGRAM_API_KEY=your_deepgram_key_here
# Diagnostic only. Keep false unless isolating Deepgram URL behavior.
DEEPGRAM_SIMPLIFY_STREAMING_URL=false
# Diagnostic only. Logs capped raw Deepgram text frames; keep false normally.
DEEPGRAM_DEBUG_RAW_MESSAGES=false
# STT scale-out ownership. Keep enabled for multi-replica ai-service deployments.
STT_ENABLE_DISTRIBUTED_OWNERSHIP=true
STT_OWNERSHIP_ENABLED=true
STT_OWNERSHIP_REDIS_URL=redis://redis:6379/2
# Optional stable replica identity. Leave blank to generate a process-local UUID.
STT_REPLICA_ID=
STT_OWNERSHIP_LEASE_TTL_SECONDS=30
STT_OWNERSHIP_COOLDOWN_TTL_SECONDS=300
HUGGINGFACE_TOKEN=your_token_here
# Server
HOST=0.0.0.0
PORT=8000

# Storage
AUDIO_STORAGE_PATH=./storage/audio
TEMP_STORAGE_PATH=./storage/temp

# Model Settings
WHISPER_MODEL=base
DEVICE=auto  # auto prefers cuda when available, otherwise cpu
ENABLE_SPEAKER_DIARIZATION=false
LAZY_LOAD_MODELS=true

# Processing
MAX_CHUNK_DURATION=30
VAD_THRESHOLD=0.5

AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama-service:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_TIMEOUT_SECONDS=300
