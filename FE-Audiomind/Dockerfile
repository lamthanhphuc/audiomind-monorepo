FROM node:20 AS build

WORKDIR /workspace/FE-Audiomind
COPY FE-Audiomind/package*.json ./
RUN rm -rf node_modules \
	&& npm ci \
	&& npm install --no-save @rollup/rollup-linux-x64-gnu

WORKDIR /workspace
COPY FE-Audiomind ./FE-Audiomind
COPY packages ./packages

WORKDIR /workspace/FE-Audiomind
ARG VITE_MEETING_API_BASE_URL
ARG VITE_PROCESSING_API_BASE_URL
ARG VITE_USER_API_BASE_URL
ARG VITE_API_BASE
ARG VITE_API_CPU_BASE
ARG VITE_API_GPU_BASE
ARG VITE_AI_SERVICE_URL
ARG VITE_REALTIME_WS_ENABLED

ENV VITE_MEETING_API_BASE_URL=$VITE_MEETING_API_BASE_URL
ENV VITE_PROCESSING_API_BASE_URL=$VITE_PROCESSING_API_BASE_URL
ENV VITE_USER_API_BASE_URL=$VITE_USER_API_BASE_URL
ENV VITE_API_BASE=$VITE_API_BASE
ENV VITE_API_CPU_BASE=$VITE_API_CPU_BASE
ENV VITE_API_GPU_BASE=$VITE_API_GPU_BASE
ENV VITE_AI_SERVICE_URL=$VITE_AI_SERVICE_URL
ENV VITE_REALTIME_WS_ENABLED=$VITE_REALTIME_WS_ENABLED

RUN npm run build-only

FROM nginx:1.27-alpine

COPY --from=build /workspace/FE-Audiomind/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
